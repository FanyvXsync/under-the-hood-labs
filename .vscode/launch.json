{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ 还原 VS2022 体验",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": true,  // 【关键点1】设为 true，自动停在 main 函数第一行
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": true, // 【关键点2】设为 true，弹出独立黑框
            "MIMode": "gdb",
            "miDebuggerPath": "gdb.exe", // 注意：这里要换成你电脑上 gdb.exe 的真实路径！
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing", // 【关键点3】让 vector/map 显示更人性化
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: g++.exe 生成活动文件"
        }
    ]
}